<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Seventy Times — Globe</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet" />
<style>
  :root {
    --black: #0a0b10;
    --bg-deep: #06060c;
    --surface: #14151c;
    --surface-2: #1c1d26;
    --surface-3: #25262f;
    --line: rgba(200, 212, 222, 0.1);
    --line-strong: rgba(200, 212, 222, 0.2);
    --line-hi: rgba(200, 212, 222, 0.36);
    --text: #e8eef4;
    --text-muted: #a8b4c0;
    --text-dim: #6c7480;
    --accent: #c8d4de;
    --accent-strong: #d8e2ec;
    --accent-deep: #8a9aa6;
    --accent-green: #4ade80;
    --ease: cubic-bezier(0.21, 0.47, 0.32, 0.98);
    --radius-pill: 100px;
    --radius-md: 16px;
    --radius-lg: 24px;
    --shadow-card: 0 20px 60px -20px rgba(0, 0, 0, 0.5);
    --shadow-xl: 0 40px 100px -20px rgba(0, 0, 0, 0.65);
    --fs-mini: 11px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: var(--black); color: var(--text); font-family: "Manrope", system-ui, sans-serif; font-feature-settings: "ss01","cv11"; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
  body { min-height: 100vh; }
  a { color: inherit; text-decoration: none; }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: var(--fs-mini); font-weight: 700; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--text-dim);
  }
  .shimmer {
    background: linear-gradient(110deg, #e8eef4 0%, #b8c8d4 40%, #e8eef4 80%);
    background-size: 200% 100%;
    -webkit-background-clip: text; background-clip: text;
    color: transparent; -webkit-text-fill-color: transparent;
    animation: shimmerSweep 6s linear infinite;
  }
  @keyframes shimmerSweep { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  .container { max-width: 1280px; margin: 0 auto; padding: 0 32px; }

  /* ── PageIntro loader ─────────────────────────────────────────── */
  .intro {
    position: fixed; inset: 0; z-index: 1000;
    background: var(--bg-deep);
    display: grid; place-items: center;
    transition: opacity 0.9s var(--ease), visibility 0.9s var(--ease);
  }
  .intro.gone { opacity: 0; visibility: hidden; }
  .intro-stage {
    position: relative;
    width: min(62vmin, 520px);
    height: min(62vmin, 520px);
    display: grid; place-items: center;
  }
  .intro-ring { position: absolute; inset: 0; transform: rotate(-90deg); }
  .intro-ring circle { fill: none; }
  .intro-ring .track { stroke: var(--line); stroke-width: 1; }
  .intro-ring .fill { stroke: var(--accent); stroke-width: 1.5; stroke-linecap: round; transition: stroke-dashoffset 0.12s linear; }
  .intro-ring .tick { stroke: var(--line-hi); stroke-width: 1; }
  .intro-globe {
    position: absolute;
    width: 62%; height: 62%;
    top: 19%; left: 19%;
  }
  .intro-brand {
    position: absolute;
    top: -72px; left: 50%; transform: translateX(-50%);
    font-size: 56px; font-weight: 800;
    letter-spacing: -0.04em; line-height: 0.9;
  }
  .intro-tags {
    position: absolute;
    bottom: -56px; left: 50%; transform: translateX(-50%);
    display: flex; gap: 18px;
    color: var(--text-dim);
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    white-space: nowrap;
  }
  .intro-tags span { position: relative; }
  .intro-tags span + span::before {
    content: "·"; position: absolute; left: -12px; color: var(--text-dim);
  }
  .intro-pct {
    position: absolute; left: 50%; bottom: -14px; transform: translateX(-50%);
    font-size: 11px; font-weight: 700; letter-spacing: 0.24em;
    color: var(--text); font-variant-numeric: tabular-nums;
    background: var(--bg-deep); padding: 0 10px;
  }
  .intro-status {
    position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
    font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--text-dim); font-weight: 700;
    background: var(--bg-deep); padding: 0 10px;
    white-space: nowrap;
  }
  .intro-skip {
    position: absolute; bottom: 32px; right: 32px;
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--text-dim);
    padding: 10px 18px;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    cursor: pointer; pointer-events: auto;
    background: rgba(200, 212, 222, 0.02);
    transition: all 0.25s var(--ease);
  }
  .intro-skip:hover { color: var(--text); border-color: var(--line-hi); }

  /* corner HUD brackets on the loader */
  .hud-bracket { position: absolute; width: 28px; height: 28px; border: 1px solid var(--line-hi); }
  .hud-bracket.tl { top: 24px; left: 24px; border-right: none; border-bottom: none; }
  .hud-bracket.tr { top: 24px; right: 24px; border-left: none; border-bottom: none; }
  .hud-bracket.bl { bottom: 24px; left: 24px; border-right: none; border-top: none; }
  .hud-bracket.br { bottom: 24px; right: 24px; border-left: none; border-top: none; }
  .hud-label {
    position: absolute; top: 24px; left: 58px;
    font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--text-dim); font-weight: 700;
  }
  .hud-label.right { left: auto; right: 58px; }
  .hud-label.bl { top: auto; bottom: 24px; left: 58px; }

  /* ── Nav ──────────────────────────────────────────────────────── */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    padding: 20px 0;
    background: rgba(10, 11, 16, 0.65);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }
  .nav-row { display: flex; align-items: center; justify-content: space-between; }
  .nav-logo { font-weight: 800; font-size: 20px; letter-spacing: -0.02em; }
  .nav-logo b { color: var(--accent); }
  .nav-links { display: flex; gap: 32px; font-size: 14px; color: var(--text-muted); }
  .nav-links a { transition: color 0.2s; }
  .nav-links a:hover { color: var(--text); }
  .nav-right { display: flex; align-items: center; gap: 18px; }
  .nav-status {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--text-muted);
  }
  .status-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent-green);
    box-shadow: 0 0 12px var(--accent-green);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100% { opacity: 0.55; } 50% { opacity: 1; } }
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px;
    background: var(--accent); color: var(--black);
    font-weight: 700; font-size: 14px;
    border-radius: var(--radius-pill);
    transition: all 0.25s var(--ease);
    cursor: pointer;
  }
  .btn:hover { background: var(--accent-strong); transform: translateY(-1px); }
  .btn-ghost {
    background: transparent; color: var(--text);
    border: 1px solid var(--line-strong);
  }
  .btn-ghost:hover { background: rgba(200, 212, 222, 0.06); border-color: var(--line-hi); }

  /* ── Hero ─────────────────────────────────────────────────────── */
  .hero {
    position: relative; min-height: 100vh;
    padding: 160px 0 80px;
    overflow: hidden;
  }
  .hero-globe {
    position: relative;
    aspect-ratio: 1 / 1;
    width: 100%;
    max-width: 520px;
    margin-left: auto;
  }
  .hero-row {
    position: relative; z-index: 2;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 48px; align-items: center;
  }
  .hero-meta {
    display: flex; gap: 24px; margin-bottom: 32px;
    color: var(--text-dim);
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 700;
  }
  .hero-meta span { position: relative; }
  .hero-meta span + span::before {
    content: ""; position: absolute; left: -12px; top: 50%;
    width: 3px; height: 3px; background: var(--text-dim); border-radius: 50%;
  }
  .hero-title {
    font-size: clamp(56px, 8vw, 128px);
    font-weight: 800; letter-spacing: -0.04em; line-height: 0.92;
    margin-bottom: 32px;
  }
  .hero-title .italic { font-style: italic; font-weight: 400; color: var(--text-muted); padding: 0 0.08em; }
  .hero-title .outline {
    -webkit-text-stroke: 1.5px var(--accent);
    -webkit-text-fill-color: transparent;
    color: transparent;
    padding: 0 0.06em;
  }
  .hero-sub {
    font-size: clamp(16px, 1.3vw, 19px);
    color: var(--text-muted);
    max-width: 560px;
    margin-bottom: 36px;
    line-height: 1.55;
  }
  .hero-ctas { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }
  .hero-hint {
    margin-top: 20px;
    font-size: 12px; color: var(--text-dim);
  }
  .hero-globe-inner {
    position: absolute; inset: 0;
  }
  .hero-hud {
    position: absolute; inset: 0;
    pointer-events: none;
  }
  .hero-hud .coord {
    position: absolute;
    font-size: 10px; letter-spacing: 0.18em;
    color: var(--text-dim); font-weight: 700;
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
  }
  .hero-hud .coord .line { display: block; width: 40px; height: 1px; background: var(--line-hi); margin: 6px 0; }
  .hero-hud .tl { top: 6%; left: 2%; }
  .hero-hud .tr { top: 6%; right: 2%; text-align: right; }
  .hero-hud .bl { bottom: 8%; left: 2%; }
  .hero-hud .br { bottom: 8%; right: 2%; text-align: right; }

  /* ── Stats row ─────────────────────────────────────────────────── */
  .stats {
    margin-top: 80px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    border-top: 1px solid var(--line);
    padding-top: 32px;
    position: relative; z-index: 2;
  }
  .stat-num {
    font-size: clamp(36px, 3.5vw, 56px);
    font-weight: 800; letter-spacing: -0.03em;
    color: var(--accent);
  }
  .stat-label {
    font-size: 11px; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--text-dim); font-weight: 700;
    margin-top: 6px;
  }

  /* ── Ambient-bg band (globe as background design element) ───── */
  .band {
    position: relative;
    padding: 180px 0;
    overflow: hidden;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .band-globe {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 160vmin; height: 160vmin;
    opacity: 0.35;
    pointer-events: none;
    mask-image: radial-gradient(circle at center, black 30%, transparent 65%);
    -webkit-mask-image: radial-gradient(circle at center, black 30%, transparent 65%);
  }
  .band-content { position: relative; z-index: 2; text-align: center; max-width: 760px; margin: 0 auto; }
  .band-title { font-size: clamp(36px, 5vw, 72px); font-weight: 800; letter-spacing: -0.03em; line-height: 1; margin: 20px 0 24px; }
  .band-title .italic { font-style: italic; font-weight: 400; color: var(--text-muted); padding: 0 0.08em; }
  .band-sub { color: var(--text-muted); font-size: 17px; line-height: 1.55; }

  /* ── CTA ──────────────────────────────────────────────────────── */
  .cta {
    position: relative;
    padding: 180px 0 200px;
    overflow: hidden;
    border-top: 1px solid var(--line);
  }
  .cta-globe {
    position: absolute;
    left: 50%; bottom: -40%;
    transform: translateX(-50%);
    width: 130vmin; height: 130vmin;
    pointer-events: none;
    mask-image: radial-gradient(circle at center, black 40%, transparent 72%);
    -webkit-mask-image: radial-gradient(circle at center, black 40%, transparent 72%);
  }
  .cta-content { position: relative; z-index: 2; text-align: center; }
  .cta-eyebrow { display: inline-flex; margin-bottom: 28px; }
  .cta-title {
    font-size: clamp(56px, 7vw, 120px);
    font-weight: 800; letter-spacing: -0.04em; line-height: 0.95;
    margin-bottom: 32px;
  }
  .cta-title .italic { font-style: italic; font-weight: 400; color: var(--text-muted); padding: 0 0.08em; }
  .cta-sub { color: var(--text-muted); max-width: 640px; margin: 0 auto 40px; font-size: 17px; line-height: 1.55; }
  .cta-ctas { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .cta-meta {
    margin-top: 80px;
    display: flex; justify-content: space-between; align-items: center;
    color: var(--text-dim);
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 700;
    border-top: 1px solid var(--line); padding-top: 32px;
  }

  /* ── Tweaks panel ─────────────────────────────────────────────── */
  .tweaks {
    position: fixed; right: 24px; bottom: 24px; z-index: 100;
    width: 260px;
    padding: 20px;
    background: rgba(20, 21, 28, 0.95);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-xl);
    backdrop-filter: blur(12px);
    display: none;
    color: var(--text);
    font-size: 13px;
  }
  .tweaks.visible { display: block; }
  .tweaks h4 {
    font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--text-dim); font-weight: 700;
    margin-bottom: 14px;
  }
  .tweak-row { margin-bottom: 14px; }
  .tweak-row label { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-muted); margin-bottom: 6px; }
  .tweak-row input[type="range"] { width: 100%; accent-color: var(--accent); }
  .tweak-row select, .tweak-row input[type="checkbox"] { accent-color: var(--accent); }

  @media (max-width: 900px) {
    .hero-row { grid-template-columns: 1fr; gap: 40px; }
    .hero-globe { max-width: 480px; margin: 0 auto; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .nav-links { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
</head>
<body>

<!-- PageIntro loader -->
<div class="intro" id="intro">
  <div class="hud-bracket tl"></div>
  <div class="hud-bracket tr"></div>
  <div class="hud-bracket bl"></div>
  <div class="hud-bracket br"></div>
