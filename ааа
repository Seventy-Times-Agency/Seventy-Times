<script>
  const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
    "density": 9,
    "greenNodes": true,
    "rings": true,
    "interactive": false
  }/*EDITMODE-END*/;
</script>
<script src="https://unpkg.com/three@0.160.0/build/three.min.js"></script>
<script src="globe.js?v=9"></script>
<script>
(async function () {
  const cfg = { ...TWEAK_DEFAULTS };

  // ── Loader globe ───────────────────────────────
  const introEl = document.getElementById("intro");
  const introGlobeEl = document.getElementById("intro-globe");

  const introGlobe = await STGlobe.mount(introGlobeEl, {
    density: cfg.density,
    interactive: true,
    fast: true,
    showRings: true,
    arcCount: 22,
    showWireframe: true,
  });

  // Build tick marks on the intro ring
  const ticks = document.getElementById("intro-ticks");
  for (let i = 0; i < 12; i++) {
    const a = (i / 12) * Math.PI * 2;
    const x1 = 100 + Math.cos(a) * 90, y1 = 100 + Math.sin(a) * 90;
    const x2 = 100 + Math.cos(a) * 86, y2 = 100 + Math.sin(a) * 86;
    ticks.innerHTML += `<line class="tick" x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" />`;
  }

  const ringFill = document.getElementById("intro-ring-fill");
  const CIRC = 2 * Math.PI * 96;
  ringFill.setAttribute("stroke-dasharray", CIRC);
  const pct = document.getElementById("intro-pct");
  const statusEl = document.getElementById("intro-status");

  // Progress sim — ramps to 100% then dismisses
  const STATUSES = ["Initializing…", "Linking nodes…", "Syncing channels…", "Online"];
  let p = 0;
  const startedAt = Date.now();
  const DURATION = 3400;
  function progress() {
    const elapsed = Date.now() - startedAt;
    p = Math.min(1, elapsed / DURATION);
    ringFill.setAttribute("stroke-dashoffset", CIRC * (1 - p));
    pct.textContent = String(Math.floor(p * 100)).padStart(2, "0") + "%";
    statusEl.textContent = STATUSES[Math.min(3, Math.floor(p * 4))];
    if (p < 1) requestAnimationFrame(progress);
    else dismissIntro();
  }
  requestAnimationFrame(progress);

  function dismissIntro() {
    introEl.classList.add("gone");
    setTimeout(() => {
      introGlobe.destroy();
      introEl.style.display = "none";
    }, 950);
  }
  document.getElementById("intro-skip").addEventListener("click", dismissIntro);

  // ── Hero globes (interactive + ambient bg) ─────
  const heroGlobeEl = document.getElementById("hero-globe");
  const heroGlobe = await STGlobe.mount(heroGlobeEl, {
    density: cfg.density,
    interactive: cfg.interactive,
    fast: false,
    showRings: cfg.rings,
    arcCount: 18,
    showWireframe: true,
  });

  const heroBgEl = document.getElementById("band-globe");
  const heroBg = await STGlobe.mount(heroBgEl, {
    density: Math.max(3, cfg.density - 1),
    interactive: false,
    fast: false,
    showRings: false,
    arcCount: 14,
  });

  // ── CTA globe ──────────────────────────────────
  const ctaEl = document.getElementById("cta-globe");
  const ctaGlobe = await STGlobe.mount(ctaEl, {
    density: cfg.density,
    interactive: false,
    fast: false,
    showRings: cfg.rings,
  });

  // ── Tweaks wiring ──────────────────────────────
  const tweaksEl = document.getElementById("tweaks");
  window.addEventListener("message", (e) => {
    const d = e.data || {};
    if (d.type === "__activate_edit_mode") tweaksEl.classList.add("visible");
    if (d.type === "__deactivate_edit_mode") tweaksEl.classList.remove("visible");
  });
  window.parent.postMessage({ type: "__edit_mode_available" }, "*");

  const densityEl = document.getElementById("tk-density");
  const densityV = document.getElementById("tk-density-v");
  densityEl.value = cfg.density;
  densityV.textContent = cfg.density;
  densityEl.addEventListener("change", () => {
    cfg.density = +densityEl.value;
    densityV.textContent = cfg.density;
    window.parent.postMessage({ type: "__edit_mode_set_keys", edits: { density: cfg.density } }, "*");
    // Rebuild just hero (cheap visual feedback)
    heroGlobe.destroy();
    STGlobe.mount(heroGlobeEl, { density: cfg.density, interactive: cfg.interactive, showRings: cfg.rings });
  });

  document.getElementById("tk-inter").addEventListener("change", (e) => {
    cfg.interactive = e.target.checked;
    heroGlobe.setInteractive(cfg.interactive);
    window.parent.postMessage({ type: "__edit_mode_set_keys", edits: { interactive: cfg.interactive } }, "*");
  });

  document.getElementById("tk-replay").addEventListener("click", () => {
    location.reload();
  });
})();
</script>
</body>
</html>
