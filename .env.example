# ── Allowed origins (CORS / CSRF protection) ────────────────
# Comma-separated list of origins allowed to call /api/* routes.
# Example: https://seventy-times.com,http://localhost:3000
# If empty, all origins are allowed (dev-only — don't ship empty).
ALLOWED_ORIGINS=https://seventy-times.com,http://localhost:3000


# ── Anthropic (Claude / Venesa chat) ────────────────────────
# Server-side key used by /api/chat route. Never exposed to the browser.
# Get it from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the Claude model (defaults to claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5


# ── Telegram notifications for /api/lead and /api/review ────
# Optional. If both are set, every form submission (заявка или отзыв)
# is forwarded to the given Telegram chat via the Bot API. Without
# these values submissions are still logged to the server console
# (visible in Vercel → Logs).
#
# How to get them:
#   1. Open @BotFather in Telegram and run /newbot, save the token it
#      gives you → that's TELEGRAM_BOT_TOKEN.
#   2. Send any message to your new bot in Telegram.
#   3. Open https://api.telegram.org/bot<TOKEN>/getUpdates in a browser
#      and copy the numeric "chat":{"id": ...} value → that's
#      TELEGRAM_CHAT_ID. (Can also be a group chat — add the bot to
#      the group first.)
#
# TELEGRAM_BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=123456789


# ── Client verification codes for /api/review ───────────────
# Comma-separated list of one-off codes you hand out to real clients
# after a project. Only submissions with a matching code are accepted
# by /api/review. Matching is case-insensitive and ignores spaces,
# dashes and underscores, so "IAA-XYZ-42" and "iaaxyz42" are equal.
#
# Rotate codes by editing this env var. After a new approved review
# you can remove or replace used codes so they can't be reused.
#
# CLIENT_CODES=IAA-XYZ-42,IAA-BECKER-01,IAA-LUMON-07
