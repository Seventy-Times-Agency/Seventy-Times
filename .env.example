# ── Allowed origins (CORS / CSRF protection) ────────────────
# Comma-separated list of origins allowed to call /api/* routes.
# Example: https://seventy-times.com,http://localhost:3000
# If empty, all origins are allowed (dev-only — don't ship empty).
ALLOWED_ORIGINS=https://seventy-times.com,http://localhost:3000


# ── Anthropic (Claude / Vanessa chat) ───────────────────────
# Server-side key used by /api/chat route. Never exposed to the browser.
# Get it from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the Claude model (defaults to claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6


# ── Telegram notifications for /api/lead, /api/review, /api/error ──
# Optional. If both are set, every form submission AND every fresh
# client-side error (deduplicated by signature for an hour) is forwarded
# to the given Telegram chat via the Bot API.
#
# How to get them:
#   1. Open @BotFather in Telegram and run /newbot, save the token it
#      gives you → that's TELEGRAM_BOT_TOKEN.
#   2. Send any message to your new bot in Telegram.
#   3. Open https://api.telegram.org/bot<TOKEN>/getUpdates in a browser
#      and copy the numeric "chat":{"id": ...} value → that's
#      TELEGRAM_CHAT_ID. (Can also be a group chat — add the bot to
#      the group first.)
#
# TELEGRAM_BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=123456789


# ── Notion CRM ──────────────────────────────────────────────
# Used by /api/lead, /api/review, and /api/chat (turn-by-turn logging).
# Each database is optional individually — set the IDs you actually use.
#
# Setup:
#   1. Create an integration at https://www.notion.so/my-integrations
#      (type: Internal). Copy its "Internal Integration Secret".
#   2. Create the three databases below with the properties listed in
#      README. Connect each one to the integration (database ⋯ →
#      Connections).
#   3. Grab each database's 32-char ID from its URL:
#      notion.so/<workspace>/<NAME>-<ID>?v=...
#
# NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_LEADS_ID=5d1403e977244b0d98a0da0ea81260b4
# NOTION_DATABASE_REVIEWS_ID=ae0e846a7f604f5dabb9858a4b7cf270
# NOTION_DATABASE_CHATS_ID=600c59d1752e49c0ad18ac896a56ba60


# ── Email fallback (Resend) for /api/lead and /api/review ───
# Optional but strongly recommended: if Telegram and Notion are both
# down (or you're switching them), the lead/review is still mirrored
# here. With NEITHER Telegram, Notion, nor email configured, /api/lead
# and /api/review return 503 instead of silently swallowing submissions.
#
# Get RESEND_API_KEY at https://resend.com — free tier is fine.
# RESEND_FROM defaults to onboarding@resend.dev which works without a
# verified domain. After you verify seventy-times.com in Resend, switch
# it to e.g. "Seventy Times <hello@seventy-times.com>".
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LEAD_NOTIFY_EMAIL=info@seventy-times.com
# RESEND_FROM=Seventy Times <onboarding@resend.dev>


# ── Client verification codes for /api/review ───────────────
# Comma-separated list of one-off codes you hand out to real clients
# after a project. Only submissions with a matching code are accepted
# by /api/review. Matching is case-insensitive and ignores spaces,
# dashes and underscores, so "IAA-XYZ-42" and "iaaxyz42" are equal.
#
# Rotate codes by editing this env var. After a new approved review
# you can remove or replace used codes so they can't be reused.
#
# CLIENT_CODES=IAA-XYZ-42,IAA-BECKER-01,IAA-LUMON-07


# ── Vercel-provided (no need to set manually) ───────────────
# These are injected automatically on every Vercel deployment and are
# only listed here so nobody hunts for where they come from:
#   VERCEL_URL / VERCEL_BRANCH_URL / VERCEL_PROJECT_PRODUCTION_URL —
#     this deployment's hostnames; /api/* origin checks trust them.
#   VERCEL_GIT_COMMIT_SHA — used to version the service-worker cache.
# Locally you can set NEXT_PUBLIC_BUILD_ID to bust the SW cache by hand.
# NEXT_PUBLIC_BUILD_ID=dev
